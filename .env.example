# Flask
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-long-random-string
JWT_SECRET_KEY=change-this-to-a-different-long-random-string

# Database
# Local dev default uses SQLite (see app/config.py). To use MySQL instead, set:
# DATABASE_URL=mysql+pymysql://lcms_user:password@localhost:3306/lcms_db
DATABASE_URL=sqlite:///lcms_dev.db

# Mail (optional — leave blank to disable email, in-app notifications still work)
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=lcms@lasu.edu.ng

# JWT cookie settings
JWT_COOKIE_SECURE=false
# Set to true in production (requires HTTPS)
